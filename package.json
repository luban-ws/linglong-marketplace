{
  "name": "linglong-marketplace",
  "private": true,
  "description": "Claude Code skill marketplace (plugins + validation)",
  "scripts": {
    "validate": "python3 -m scripts.validate_marketplace",
    "test": "python3 -m unittest discover -s tests -p 'test_*.py' -v",
    "build:site": "python3 scripts/build_site.py --out _site",
    "deploy:pages": "bash scripts/deploy-gh-pages.sh",
    "check": "npm run validate && npm test",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
